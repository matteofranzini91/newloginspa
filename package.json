{
  "name": "newloginspa",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config ./config/vite/vite.config.ts --mode dev",
    "build": "vite build --config ./config/vite/vite.config.ts --mode prod",
    "preview": "vite preview --config ./config/vite/vite.config.ts --mode prod",
    "lint": "eslint --fix",
    "lint:verify": "eslint .",
    "format": "prettier --write",
    "format:verify": "prettier .",
    "test": "vitest run --config ./config/vite/vite.config.ts",
    "test:watch": "vitest --config ./config/vite/vite.config.ts",
    "json-server": "nodemon ./json-server/server.mjs",
    "dev:all": "concurrently -k -n vite,api -c blue,green \"pnpm dev\" \"pnpm json-server\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.0.1",
    "@mui/material": "9.0.1",
    "@mui/x-date-pickers": "^9.2.0",
    "@reduxjs/toolkit": "2.11.2",
    "axios": "1.16.0",
    "dayjs": "1.11.20",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "notistack": "^3.0.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "^17.0.8",
    "react-redux": "9.2.0",
    "react-router-dom": "7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "^9.2.1",
    "dotenv": "17.4.2",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "json-server": "1.0.0-beta.15",
    "lint-staged": "17.0.4",
    "nodemon": "3.1.14",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.6"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}